# ─────────────────────────────────────────────────────────────────────────────
#  .env.example  –  Copy this to .env and fill in your values
#  NEVER commit .env to version control
# ─────────────────────────────────────────────────────────────────────────────

# ── Flask ─────────────────────────────────────────────────────────────────────
SECRET_KEY=your_secret_key_here

# ── PostgreSQL (LOCAL dev only) ───────────────────────────────────────────────
# On Render, set DATABASE_URL instead (Render sets this automatically for
# managed PostgreSQL databases — you do NOT need the individual vars below)
DB_HOST=localhost
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=itcg_registration
DB_PORT=5432

# ── OR use a full connection URL (Render managed DB) ─────────────────────────
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Email (SMTP / Flask-Mail) ─────────────────────────────────────────────────
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_gmail_app_password
MAIL_DEFAULT_SENDER=your_email@gmail.com

# ── Accountant (static / BCC) email ──────────────────────────────────────────
ACCOUNTANT_EMAIL=accountant@yourcompany.com

# ── wkhtmltopdf ───────────────────────────────────────────────────────────────
# Linux/Render (default, no need to set):  /usr/bin/wkhtmltopdf
# Windows local dev:
# WKHTMLTOPDF_PATH=C:\Program Files\wkhtmltopdf\bin\wkhtmltopdf.exe
